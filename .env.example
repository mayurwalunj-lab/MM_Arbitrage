# Copy this file to .env and fill secrets on the machine running the services.

# MM bot dry-run master switch. Dry-run (simulate) unless set to exactly
# 'false'. Production MUST set BOT_DRY_RUN=false or the bots won't trade.
BOT_DRY_RUN=false

# SINGLE database config — used by bots, dashboard, arb module, migrations.
# (Legacy BITMART_DB_* / LBANK_DB_* keys still work as fallback if DB_* unset.)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=mm_production

# Uniswap L1X/WETH trading
ETH_RPC_URL=
# ETH/USD resolution order: live CEX (Bitmart/LBank) -> Chainlink on-chain feed
# -> this static value (last resort). Set ETH_USD_PRICE only as a final safety net.
ETH_USD_PRICE=
# Chainlink ETH/USD feed — on-chain fallback when the live CEX fetch fails (uses
# ETH_RPC_URL, no API key). Defaults to the mainnet feed. Reject answers older
# than CHAINLINK_MAX_STALE_SECONDS (0 disables the staleness check).
CHAINLINK_ETH_USD_FEED=0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419
CHAINLINK_MAX_STALE_SECONDS=3600
UNISWAP_WALLET_PRIVATE_KEY=
UNISWAP_WALLET_ADDRESS=
UNISWAP_CHAIN_ID=1
L1X_TOKEN_ADDRESS=0x399Ef659FDeAD53B3E7f97E9491E727925667945
L1X_WETH_POOL_ADDRESS=0x9Fb1a1a98F995b2B3362a1238De1366BFa790006
WETH_ADDRESS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
UNISWAP_QUOTER_V2_ADDRESS=0x61fFE014bA17989E743c5F6cB21bF9697530B21e
UNISWAP_SWAP_ROUTER_02_ADDRESS=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
UNISWAP_DEFAULT_SLIPPAGE_BPS=100
UNISWAP_DEADLINE_SECONDS=600

# CEX->DEX arbitrage monitor (arb/monitor.js). Detection is dry-run only.
# Order placement stays blocked unless ARB_DRY_RUN=false is set explicitly.
ARB_DRY_RUN=true
ARB_PAIR=L1X/USDT
ARB_POLL_MS=5000
ARB_MIN_EDGE_USD=20
ARB_MIN_TRADE_L1X=10
ARB_MAX_TRADE_L1X=1000
ARB_CEX_TAKER_FEE_BPS=25
ARB_GAS_LIMIT_SWAP=200000
ARB_MAX_SPREAD_PCT=2
ARB_MIN_DEPTH_L1X=50
ARB_DEPTH_RANGE_PCT=2
ARB_PERSIST_TICKS=3
ARB_STALE_MS=3000
ARB_OWN_ORDERS_TTL_MS=10000
# false = evaluate the raw book INCLUDING our own grid/MM orders. Detection
# data only — never execute on it (buying your own orders is wash trading).
ARB_SELF_TRADE_FILTER=true
# Execution (Phase 2). ARB_DRY_RUN=false is the master lock for live orders.
# Stage A: npm run arb:execute (one command-triggered round).
# Stage B/C: ARB_AUTO_EXECUTE=true lets the monitor fire rounds itself, only
# above ARB_AUTO_MIN_EDGE_USD and within every cap below.
ARB_AUTO_EXECUTE=false
ARB_AUTO_MIN_EDGE_USD=40
# Hedge mode (leg 3): cex = sell ETH on exchange (USDT on exchange, needs
# exchange ETH); dex = swap WETH->USDT on Uniswap each trade (USDT in wallet,
# extra gas, no exchange ETH); skip = keep WETH, convert later via arb:convert
# (lowest gas, ETH-exposed until converted).
ARB_HEDGE_MODE=cex
# WETH->USDT conversion (for `arb:convert`). USDT_ADDRESS + the pool fee tier
# of the WETH/USDT Uniswap pool (500 = 0.05%, the deep ETH/USDT tier).
USDT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
UNISWAP_USDT_POOL_FEE=500

# Treasury sell (arb/treasury_sell.js): sell treasury L1X on the DEX when it
# trades above the CEX price (down to the CEX price), convert to USDT.
# Directional (treasury L1X decreases) — not arbitrage. CEX price is the floor.
# TREASURY_MODE gates allowed directions: sell (only sell L1X when DEX above
# CEX) | buy (only buy back when DEX below CEX) | both. A blocked direction
# refuses to run.
# Live trading master switch for the treasury monitor (treasury_monitor under
# PM2). true = real sells/buys; anything else (or unset) = dry-run/simulate.
# Fail-safe: defaults to dry-run. The --execute CLI flag also forces live.
TREASURY_EXECUTE=false
TREASURY_MODE=both
TREASURY_MIN_PREMIUM_PCT=0.5
TREASURY_MAX_SELL_L1X=50
TREASURY_MAX_BUY_L1X=50
# Hard daily L1X volume cap (LIVE trades only), enforced per direction: at most
# this many L1X sold AND this many L1X bought per calendar day. Once reached,
# that direction skips for the rest of the day. dry-run is uncapped.
TREASURY_MAX_L1X_PER_DAY=50
TREASURY_SLIPPAGE_BPS=100
TREASURY_CONVERT_USDT=true
# Treasury monitor loop (treasury:monitor): poll interval, cooldown after an
# action, and a daily cap on LIVE trades (dry-run is uncapped).
TREASURY_POLL_MS=30000
TREASURY_COOLDOWN_MS=60000
TREASURY_MAX_TRADES_PER_DAY=20
ARB_EXEC_MAX_TRADE_USD=200
ARB_EXEC_MAX_TRADES_PER_HOUR=6
ARB_EXEC_DAILY_LOSS_LIMIT_USD=20
ARB_EXEC_LEG_TIMEOUT_MS=10000
ARB_EXEC_PRICE_BUFFER_BPS=10
ARB_EXEC_COOLDOWN_MS=60000
ARB_EXEC_SLIPPAGE_BPS=100
# Dedicated arb trading keys (NOT the MM/grid bot keys). Optional for the
# monitor: without them orderbooks still work, balances/orders do not.
ARB_BITMART_API_KEY=
ARB_BITMART_SECRET=
ARB_BITMART_UID=
ARB_LBANK_API_KEY=
ARB_LBANK_SECRET=
# Accounting DB for arb_* tables. Optional: falls back to BITMART_DB_* when
# unset (same MySQL server the MM bots use).
#ARB_DB_HOST=
#ARB_DB_PORT=
#ARB_DB_USER=
#ARB_DB_PASSWORD=
#ARB_DB_NAME=
